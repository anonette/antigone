# Copy to .env (never commit .env)
#
# OpenAI models (openai/* in config/models.yaml) use OPENAI_API_KEY → api.openai.com
OPENAI_API_KEY=sk-...

# All other models use OPENROUTER_API_KEY → openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: push runs to Antigone Lab (Lovable) after collection
ANTIGONE_INGEST_SECRET=your-random-secret-matching-lovable-backend
LOVABLE_INGEST_URL=https://your-app.lovable.app/api/public/ingest

# Or push without HTTP (Lovable Cloud → API → service_role):
# SUPABASE_URL=https://ssxrezezuydvzzjdlktr.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_IMPORTS_TABLE=antigone_imports
